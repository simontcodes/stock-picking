generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AlertSignal {
  BUY
  SELL
}

enum AlertDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions             AuthSession[]
  invitationsSent      Invitation[]          @relation("InvitationsSent")
  watchlists           Watchlist[]
  watchlistAlerts      WatchlistAlert[]
  watchlistSignalStates WatchlistSignalState[]
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  tokenHash   String    @unique
  invitedById String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  invitedBy User? @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([expiresAt])
  @@index([invitedById])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Watchlist {
  id        String          @id @default(cuid())
  userId    String
  name      String
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WatchlistItem[]

  @@index([userId])
  @@index([userId, isDefault])
}

model WatchlistItem {
  id          String    @id @default(cuid())
  watchlistId String
  ticker      String
  notes       String?
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, ticker])
  @@index([watchlistId])
  @@index([ticker])
}

model WatchlistAlert {
  id                    String              @id @default(cuid())
  userId                String
  ticker                String
  signal                AlertSignal
  candleDate            DateTime
  overallCrossoverType  String
  macdCrossoverType     String
  overallCrossoverAt    DateTime
  macdCrossoverAt       DateTime
  notificationStatus    AlertDeliveryStatus @default(PENDING)
  notificationAttempts  Int                 @default(0)
  lastNotifiedAt        DateTime?
  lastNotificationError String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications AlertNotification[]

  @@unique([userId, ticker, signal, candleDate])
  @@index([userId])
  @@index([userId, ticker, candleDate])
  @@index([notificationStatus])
}

model WatchlistSignalState {
  id                   String      @id @default(cuid())
  userId               String
  ticker               String
  signal               AlertSignal
  signalDate           DateTime
  overallSignalDate    DateTime
  macdSignalDate       DateTime
  overallCrossoverType String
  macdCrossoverType    String
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
  @@index([signal])
  @@index([signalDate])
}

model AlertNotification {
  id         String              @id @default(cuid())
  alertId    String
  channel    String
  status     AlertDeliveryStatus
  message    String?
  error      String?
  attemptedAt DateTime           @default(now())

  alert WatchlistAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@index([channel, attemptedAt])
}
